{
  "name": "iconsearch-integration",
  "displayName": "IconSearch Integration",
  "description": "Search and insert 351,639 free online icons from 16 named libraries and 224 Iconify collections. Secure IconSearch account connection included.",
  "version": "1.0.1",
  "publisher": "IconSearch",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sg-2512/iconsearch.git"
  },
  "homepage": "https://iconsearch.info/vscode-extension",
  "bugs": {
    "url": "https://github.com/sg-2512/iconsearch/issues"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "iconsearch-explorer",
          "title": "IconSearch",
          "icon": "$(search)"
        }
      ]
    },
    "views": {
      "iconsearch-explorer": [
        {
          "type": "webview",
          "id": "iconsearch.sidebar",
          "name": "Search & Insert"
        }
      ]
    },
    "commands": [
      {
        "command": "iconsearch-integration.search",
        "title": "Focus IconSearch",
        "category": "IconSearch"
      }
    ],
    "keybindings": [
      {
        "command": "iconsearch-integration.search",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "IconSearch Integration",
      "properties": {
        "iconSearch.defaultFormat": {
          "type": "string",
          "enum": [
            "ask",
            "react",
            "svg",
            "vue",
            "svelte",
            "tailwind"
          ],
          "default": "ask",
          "description": "The default format to insert icons. 'ask' shows a selection menu each time."
        },
        "iconSearch.tailwindClasses": {
          "type": "string",
          "default": "w-5 h-5",
          "description": "Tailwind CSS classes to automatically append to class/className attributes."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  }
}
